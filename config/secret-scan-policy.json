{
  "scanRoots": [
    ".github",
    "apps",
    "packages",
    "tools",
    "tests",
    "config",
    "docs",
    "fixtures",
    "README.md"
  ],
  "excludePrefixes": [
    "node_modules/",
    ".git/",
    ".tmp/",
    "dist/",
    ".test-dist/"
  ],
  "excludeSuffixes": [
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".ico",
    ".pdf",
    ".zip",
    ".gz",
    ".lock"
  ],
  "patterns": [
    {
      "id": "private-key-header",
      "regex": "-----BEGIN (RSA |EC |OPENSSH |)?PRIVATE KEY-----"
    },
    {
      "id": "github-pat",
      "regex": "ghp_[A-Za-z0-9]{36}"
    },
    {
      "id": "aws-access-key-id",
      "regex": "AKIA[0-9A-Z]{16}"
    },
    {
      "id": "stripe-live-key",
      "regex": "sk_live_[A-Za-z0-9]{24,}"
    }
  ],
  "allowlist": [
    {
      "file": "tools/scan-secrets.test.mjs",
      "patternId": "private-key-header"
    },
    {
      "file": "tools/scan-secrets.test.mjs",
      "patternId": "github-pat"
    }
  ]
}
