{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://product-generator-wizard.dev/schemas/manifest/v1/manifest.schema.json",
  "title": "Product Generator Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatorVersion",
    "intake",
    "artifactPlan",
    "permissions",
    "canonicalCoverage",
    "integrations",
    "determinism"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "generatorVersion": { "type": "string", "minLength": 1 },
    "intake": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "productId", "productType", "tenant"],
      "properties": {
        "schemaVersion": { "type": "string", "const": "1.0.0" },
        "productId": { "type": "string", "minLength": 1 },
        "productType": { "type": "string", "minLength": 1 },
        "tenant": { "type": "string", "minLength": 1 }
      }
    },
    "artifactPlan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["json", "markdown", "typescript", "directory"] }
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bucs", "firm", "company"],
      "properties": {
        "bucs": { "$ref": "#/$defs/permissionSummary" },
        "firm": { "$ref": "#/$defs/permissionSummary" },
        "company": { "$ref": "#/$defs/permissionSummary" }
      }
    },
    "canonicalCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mappedFields", "coveragePercent"],
      "properties": {
        "mappedFields": { "type": "integer", "minimum": 0 },
        "coveragePercent": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "integrations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workforce", "excelPlugin"],
      "properties": {
        "workforce": { "$ref": "#/$defs/integrationToggle" },
        "excelPlugin": { "$ref": "#/$defs/integrationToggle" }
      }
    },
    "determinism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stableKeyOrder", "stableFileOrder", "timestampPolicy"],
      "properties": {
        "stableKeyOrder": { "type": "boolean" },
        "stableFileOrder": { "type": "boolean" },
        "timestampPolicy": { "type": "string", "enum": ["none", "normalized-utc"] }
      }
    }
  },
  "$defs": {
    "permissionSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roles", "permissions"],
      "properties": {
        "roles": { "type": "integer", "minimum": 0 },
        "permissions": { "type": "integer", "minimum": 0 }
      }
    },
    "integrationToggle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "details": { "type": "string" }
      }
    }
  }
}
