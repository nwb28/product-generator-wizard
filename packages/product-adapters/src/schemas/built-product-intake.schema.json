{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pgw/contracts/built-product-intake.schema.json",
  "title": "Built Product Intake",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "adapter", "tenant", "product", "integrations", "permissions", "mappings"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      }
    },
    "tenant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "displayName"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 }
      }
    },
    "integrations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workforce", "excelPlugin"],
      "properties": {
        "workforce": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "details": {
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        "excelPlugin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "details": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bucs", "firm", "company"],
      "properties": {
        "bucs": { "$ref": "#/$defs/permissionMatrix" },
        "firm": { "$ref": "#/$defs/permissionMatrix" },
        "company": { "$ref": "#/$defs/permissionMatrix" }
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["canonicalModel", "sourcePath", "confidence"],
        "properties": {
          "canonicalModel": { "type": "string", "minLength": 1 },
          "sourcePath": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  },
  "$defs": {
    "permissionMatrix": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "permissions"],
        "properties": {
          "role": { "type": "string", "minLength": 1 },
          "permissions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
