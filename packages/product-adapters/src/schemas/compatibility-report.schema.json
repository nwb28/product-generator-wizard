{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pgw/contracts/compatibility-report.schema.json",
  "title": "Compatibility Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "adapter", "summary", "diagnostics", "recommendation"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocking", "warning", "readinessScore"],
      "properties": {
        "blocking": { "type": "integer", "minimum": 0 },
        "warning": { "type": "integer", "minimum": 0 },
        "readinessScore": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "path", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["blocking", "warning"] },
          "path": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "recommendation": {
      "type": "string",
      "enum": ["Go", "No-Go"]
    }
  }
}
